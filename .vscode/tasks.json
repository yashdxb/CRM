{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Open API Terminal",
      "type": "shell",
      "command": "cd \"${workspaceFolder}/server/src/CRM.Enterprise.Api\" && exec zsh",
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "group": "dev-terminals",
        "focus": false,
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Open Client Terminal",
      "type": "shell",
      "command": "cd \"${workspaceFolder}/client\" && exec zsh",
      "problemMatcher": [],
      "presentation": {
        "panel": "dedicated",
        "group": "dev-terminals",
        "focus": false,
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "build-api",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/server/src/CRM.Enterprise.Api/CRM.Enterprise.Api.csproj"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "type": "npm",
      "script": "start",
      "path": "client",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "path": "client",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "(.*?)"
          },
          "endsPattern": {
            "regexp": "bundle generation complete"
          }
        }
      }
    }
  ]
}